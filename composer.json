{
  "type": "library",
  "name": "zoujingli/ip2region",
  "homepage": "https://github.com/zoujingli/Ip2Region",
  "description": "ip2region v3.0 for PHP - 企业级 IP 地理位置查询库，支持 IPv4 和 IPv6，自动缓存，零依赖，开箱即用",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com",
      "homepage": "https://thinkadmin.top"
    }
  ],
  "require": {
    "php": ">=5.4.0"
  },
  "suggest": {
    "ext-opcache": "启用 OPcache 以获得更好的性能"
  },
  "keywords": [
    "ip2region",
    "ip",
    "location",
    "geolocation",
    "ipv4",
    "ipv6",
    "php",
    "composer",
    "压缩数据库",
    "自动压缩",
    "高性能",
    "企业级",
    "零依赖"
  ],
  "bin": [
    "bin/ip2down"
  ],
  "autoload": {
    "classmap": [
      "src/"
    ],
    "files": [
      "function.php"
    ]
  },
  "scripts": {
    "demo": "php tests/demo.php",
    "test:ipv4": "php -r \"require 'function.php'; echo ip2region('61.142.118.231') . PHP_EOL;\"",
    "test:ipv6": "php -r \"require 'function.php'; echo ip2region('2001:4860:4860::8888') . PHP_EOL;\"",
    "test:search": "php -r \"require 'function.php'; echo ip2region('61.142.118.231', 'search') . PHP_EOL;\"",
    "test:memory": "php -r \"require 'function.php'; echo json_encode(ip2region('61.142.118.231', 'memory'), JSON_UNESCAPED_UNICODE) . PHP_EOL;\"",
    "query": "php -r \"require 'function.php'; echo ip2region(\\$argv[1]) . PHP_EOL;\"",
    "query:search": "php -r \"require 'function.php'; echo ip2region(\\$argv[1], 'search') . PHP_EOL;\"",
    "query:memory": "php -r \"require 'function.php'; echo json_encode(ip2region(\\$argv[1], 'memory'), JSON_UNESCAPED_UNICODE) . PHP_EOL;\"",
    "compress:v4": "php tools/compress_db.php ip2region_v4.xdb gzip",
    "compress:v4:zip": "php tools/compress_db.php ip2region_v4.xdb zip",
    "compress:v4:zstd": "php tools/compress_db.php ip2region_v4.xdb zstd",
    "test:performance": "php tests/quick_performance_test.php",
    "download-db": "ip2down download all",
    "download-db:v4": "ip2down download v4",
    "download-db:v6": "ip2down download v6"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "branch-alias": {
      "dev-master": "3.0.x-dev"
    }
  }
}